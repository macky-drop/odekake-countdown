---
import InputForm from "../components/InputForm.astro"
import RouteList from "../components/RouteList.astro"
import Countdown from "../components/Countdown.astro"
import { mockRoutes } from "../lib/routes"
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>おでかけカウントダウン</title>
  </head>
  <body>
    <h1>おでかけカウントダウン＆時刻表</h1>

    <section>
      <InputForm />
    </section>

    <section>
      <h2>経路候補</h2>
      <RouteList routes={mockRoutes} />
    </section>

    <section>
      <h2>カウントダウン</h2>
      <Countdown />
    </section>
  </body>
</html>
